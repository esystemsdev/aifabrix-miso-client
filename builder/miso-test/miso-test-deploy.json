{
  "key": "miso-test",
  "displayName": "Miso Test",
  "description": "Production-ready demonstration application showcasing all DataClient capabilities from the AI Fabrix Miso Client SDK. Features interactive demo UI for testing authentication, HTTP methods, caching, retry logic, interceptors, metrics, audit logging, and error handling.",
  "type": "webapp",
  "version": "1.0.0",
  "image": "aifabrixdevacr.azurecr.io/miso-test:latest",
  "registryMode": "external",
  "port": 3083,
  "requiresDatabase": false,
  "requiresRedis": false,
  "requiresStorage": false,
  "databases": [],
  "configuration": [],
  "healthCheck": {
    "path": "/health",
    "interval": 30
  },
  "authentication": {
    "enableSSO": true,
    "type": "azure",
    "requiredRoles": [
      "aifabrix-user"
    ]
  },
  "roles": [
    {
      "name": "AI Fabrix Admin",
      "value": "aifabrix-admin",
      "description": "Full access to all application features and configurations"
    },
    {
      "name": "AI Fabrix User",
      "value": "aifabrix-user",
      "description": "Basic user access to the application"
    },
    {
      "name": "AI Fabrix Developer",
      "value": "aifabrix-developer",
      "description": "Developer access for testing and debugging"
    }
  ],
  "permissions": [
    {
      "name": "miso-test:read",
      "roles": [
        "aifabrix-user",
        "aifabrix-admin",
        "aifabrix-developer"
      ],
      "description": "Read access to application data"
    },
    {
      "name": "miso-test:write",
      "roles": [
        "aifabrix-admin",
        "aifabrix-developer"
      ],
      "description": "Create and edit application data"
    },
    {
      "name": "miso-test:delete",
      "roles": [
        "aifabrix-admin"
      ],
      "description": "Delete application data"
    },
    {
      "name": "miso-test:admin",
      "roles": [
        "aifabrix-admin"
      ],
      "description": "Administrative access to application configuration"
    }
  ],
  "build": {
    "envOutputPath": "../../.env"
  }
}